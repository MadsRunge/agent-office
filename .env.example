# ── Slack ──────────────────────────────────────────────────────────────────────
# Bot token (xoxb-...)  – from OAuth & Permissions in your Slack App settings
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-level token (xapp-...) – for Socket Mode, requires connections:write scope
SLACK_APP_TOKEN=xapp-your-app-token-here

# Signing secret – from Basic Information > App Credentials
SLACK_SIGNING_SECRET=your-signing-secret-here

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get token from @BotFather on Telegram → /newbot
# Leave blank to disable Telegram (Slack will still run)
TELEGRAM_BOT_TOKEN=

# ── Anthropic (Claude) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Download credentials.json from Google Cloud Console → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/callback

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# Path to store encrypted OAuth tokens (default: .tokens/)
TOKEN_STORE_DIR=.tokens

# ── Whisper (local whisper.cpp) ────────────────────────────────────────────────
# Path to compiled whisper-cli binary
WHISPER_CLI_PATH=/usr/local/bin/whisper-cli
# Path to ggml model file  (e.g. ggml-base.en.bin)
WHISPER_MODEL_PATH=~/.whisper/ggml-base.en.bin
# ffmpeg binary path (for audio conversion)
FFMPEG_PATH=ffmpeg

# ── Agent behaviour ────────────────────────────────────────────────────────────
# Claude model to use for planning
CLAUDE_MODEL=claude-sonnet-4-6
# Confirmation TTL in seconds (default 300 = 5 min)
CONFIRMATION_TTL_SECONDS=300
# Max user input length (characters)
MAX_INPUT_LENGTH=2000

# ── OAuth server ───────────────────────────────────────────────────────────────
OAUTH_SERVER_HOST=0.0.0.0
OAUTH_SERVER_PORT=8080
